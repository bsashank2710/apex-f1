# Copy to `.env`. Restart Expo after changes (`EXPO_PUBLIC_*` is baked in at bundler start).

# ── Expo workflow (phone) ───────────────────────────────────────────────────
# From repo root:  npm run expo:login     → browser sign-in
#                   npm run expo:project  → opens https://expo.dev/.../apex-f1
#                   npm run dev:phone     → QR in terminal → scan with Expo Go
# Or from mobile/:  npm run expo:login && npm run dev:phone

# Production / Cloud Run (recommended — app works without a local backend):
EXPO_PUBLIC_API_URL=https://apex-f1-api-dlum7qomda-uc.a.run.app
# Omit this line entirely to use the same URL from `lib/config.ts` DEFAULT_API_BASE_URL.

# Finished-race mode (default): last completed GP from Ergast/FastF1 — no OpenF1 “latest” or live WebSocket.
# Set to false for live timing + LATEST SESSION (needs OpenF1 credentials on the backend).
EXPO_PUBLIC_HISTORICAL_ONLY=true
# Optional: force-hide intro even in live mode (historical mode skips intro automatically).
# EXPO_PUBLIC_SKIP_INTRO=true
# After starting the API, open GET {EXPO_PUBLIC_API_URL}/health/deps — if openf1_data_ok is false, the
# backend needs OPENF1_USERNAME+OPENF1_PASSWORD (or OPENF1_ACCESS_TOKEN) in backend/.env.

# Local API on this machine:
# - Web emulator: http://127.0.0.1:8000
# - Physical phone/tablet (same Wi‑Fi): your PC’s LAN IP — run `npm run lan-api-url` in mobile/
#   then put that line in `.env`, e.g. EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

EXPO_PUBLIC_API_KEY=

# Intel / AI: same Anthropic key as console.anthropic.com — sent as X-Anthropic-Key on /ai/* when set.
# No quotes: EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-...
# Restart Expo after editing (`npx expo start --clear`). metro.config.js loads this folder’s .env early for web.
# Web dev fallback if the bundle still misses the var: DevTools → localStorage.setItem('APEX_ANTHROPIC_KEY','sk-ant-...'); location.reload()
# EAS: set in Expo dashboard. Server may use ANTHROPIC_API_KEY instead (Cloud Run).
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# EAS cloud build + install QR (Expo’s own terminal UI): from mobile/
#   npm run build:android:preview
# Uses `--wait` and stays interactive — when the build finishes, the CLI prints the install QR
# (same as the website). Do NOT use `build:android:ci` for that; `--non-interactive` hides the QR.
#
# `npm run dev:phone` (repo root) = Expo Go dev QR (Metro), not the store/APK install QR.
# Metro is tunneled; your API must still be reachable from the phone (LAN IP in .env on same Wi‑Fi,
# or the Cloud Run URL above if the phone is on another network).

# EAS: `eas.json` sets EXPO_PUBLIC_API_URL for preview/production builds.
