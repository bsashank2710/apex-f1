{
  "name": "mobile",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "dev": "npm run dev --prefix ..",
    "qr": "npm run dev:phone --prefix ..",
    "qr:apk": "node ./scripts/qr-install-apk.js",
    "dev:phone": "npm run dev:phone --prefix ..",
    "dev:phone:lan": "npm run dev:phone:lan --prefix ..",
    "start": "env -u CI expo start",
    "start:tunnel": "env -u CI expo start --tunnel --go",
    "start:lan": "env -u CI expo start --lan --go",
    "lan-api-url": "node ./scripts/lan-api-url.js",
    "expo:login": "npx expo login -b",
    "expo:whoami": "npx expo whoami",
    "expo:project": "node ./scripts/open-expo-project.js",
    "eas:login": "npx eas-cli@latest login",
    "eas:whoami": "npx eas-cli@latest whoami",
    "start:8082": "expo start --port 8082",
    "start:clear": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "eas:init": "npx eas-cli@latest init",
    "eas:update:configure": "npx eas-cli@latest update:configure",
    "build:android": "npx eas-cli@latest build --platform android --profile preview --wait",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview --wait",
    "build:android:ci": "npx eas-cli@latest build --platform android --profile preview --non-interactive",
    "build:android:production": "npx eas-cli@latest build --platform android --profile production --wait",
    "build:android:production:ci": "npx eas-cli@latest build --platform android --profile production --non-interactive",
    "build:android:local": "npx eas-cli@latest build --platform android --profile preview --local",
    "build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview --wait",
    "build:ios:production": "npx eas-cli@latest build --platform ios --profile production --wait",
    "update:preview": "npx eas-cli@latest update --channel preview --environment preview --message \"OTA update\"",
    "update:production": "npx eas-cli@latest update --channel production --environment production --message \"OTA update\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.94.5",
    "expo": "~55.0.8",
    "expo-av": "^16.0.8",
    "expo-constants": "~55.0.8",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "qrcode-terminal": "^0.12.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  },
  "engines": {
    "node": "20.x"
  },
  "private": true
}
