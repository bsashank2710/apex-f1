# Optional if the app sends X-Anthropic-Key (EXPO_PUBLIC_ANTHROPIC_API_KEY). Prefer this on servers you control.
ANTHROPIC_API_KEY=sk-ant-...
REDIS_URL=redis://localhost:6379
# If Redis isn’t running, remove REDIS_URL — otherwise every cache lookup waits for connect timeout.
# Skip heavy FastF1 startup warmups (dev): DISABLE_STARTUP_WARMUP=1
# Not used by the API yet (reserved). Safe to omit.
DATABASE_URL=postgresql://user:password@localhost:5432/apex_f1
OPENF1_BASE_URL=https://api.openf1.org/v1
# OpenF1: optional. Without credentials you still get Ergast calendar + Race/Quali/Sprint picks
# and lap timing / pit-stop “stints” from Jolpica for finished races (no live GPS / no tyre compounds).
# For live OpenF1 feeds, use (https://openf1.org/auth.html):
# OPENF1_ACCESS_TOKEN=...   # Bearer from POST https://api.openf1.org/token (expires ~1h; refresh manually or use below)
# OPENF1_USERNAME=...
# OPENF1_PASSWORD=...
# OPENF1_TOKEN_URL=https://api.openf1.org/token
ERGAST_BASE_URL=https://api.jolpi.ca/ergast/f1
FASTF1_CACHE_DIR=/var/cache/fastf1
# Redis TTL (seconds) for FastF1-shaped /live/* cache when using Ergast session picks — lower = fresher data after each GP.
FASTF1_LIVE_CACHE_TTL=180
# Optional: if set, all routes except /health, /health/deps, /docs require header X-API-Key
# WebSocket: ws://host/ws/race?api_key=...
API_KEY=
# Comma-separated. If not "*", local Expo web origins (localhost:8081, etc.) are merged automatically.
ALLOWED_ORIGINS=*
